<?xml version="1.0" encoding="utf-8"?><feed xml:lang="zh-cn" xmlns="http://www.w3.org/2005/Atom"><author><email>yuxi.zhonggg@gmail.com</email><name>Yuxi Zhong</name><uri>https://zhong-yuxi.github.io/</uri></author><icon>https://zhong-yuxi.github.io/zh/</icon><id>tag:zhong-yuxi.github.io,0001-01-01:/zh/atom.xml</id><link href="https://zhong-yuxi.github.io/zh/atom.xml" hreflang="zh-cn" rel="self" type="application/atom+xml"/><link href="https://zhong-yuxi.github.io/zh/atom.xml" hreflang="zh-cn" rel="alternate" type="application/atom+xml"/><link href="https://zhong-yuxi.github.io/zh/" hreflang="zh-cn" rel="alternate" type="text/html"/><link href="https://zhong-yuxi.github.io/zh/paige-search.json" hreflang="zh-cn" rel="alternate" type="application/json"/><link href="https://zhong-yuxi.github.io/zh/rss.xml" hreflang="zh-cn" rel="alternate" type="application/rss+xml"/><link href="https://zhong-yuxi.github.io/atom.xml" hreflang="en-us" rel="alternate" type="application/atom+xml"/><link href="https://zhong-yuxi.github.io/" hreflang="en-us" rel="canonical" type="text/html"/><link href="https://zhong-yuxi.github.io/paige-search.json" hreflang="en-us" rel="alternate" type="application/json"/><link href="https://zhong-yuxi.github.io/rss.xml" hreflang="en-us" rel="alternate" type="application/rss+xml"/><logo>https://zhong-yuxi.github.io/zh/</logo><rights type="html">© 2026 Yuxi Zhong</rights><subtitle type="html">物质文化、西藏、猫、灶</subtitle><title type="html">钟誉熙</title><updated>0001-01-01T00:00:00Z</updated><entry><content type="html"><![CDATA[<div id=stage-1 class="container-fluid px-0 text-center my-5 breakout-width"><h3 class="fw-bold mb-5" style=font-family:myjost,sans-serif;color:#008b8b>选择一尊你喜欢的灶台</h3><div class="row justify-content-center g-4"><div class="col-12 col-md-4"><img src=/projects/om-and-xiang/stove1.jpg class="img-fluid w-100 rounded-2 shadow stove-option" onclick='enterStage2("/projects/om-and-xiang/stove1.jpg")' alt="Stove 1"></div><div class="col-12 col-md-4"><img src=/projects/om-and-xiang/stove2.jpg class="img-fluid w-100 rounded-2 shadow stove-option" onclick='enterStage2("/projects/om-and-xiang/stove2.jpg")' alt="Stove 2"></div><div class="col-12 col-md-4"><img src=/projects/om-and-xiang/stove3.jpg class="img-fluid w-100 rounded-2 shadow stove-option" onclick='enterStage2("/projects/om-and-xiang/stove3.jpg")' alt="Stove 3"></div></div></div><div id=stage-2 class="container-fluid px-0 d-none my-4"><button onclick=goBack() class="btn btn-sm btn-outline-secondary mb-3" style=font-family:myjost,sans-serif>&larr; 返回</button><div class="d-flex w-100" style=gap:20px><div id=main-image-wrapper class=transition-layout style=width:100%><div id=explore-hint class="text-center mb-3 fw-bold" style=font-family:myjost,sans-serif;color:#008b8b>✨ 点击圆圈探索你更多你想了解的细节</div><div class="position-relative w-100"><img id=main-enlarged-img src class="img-fluid rounded-4 shadow w-100" alt="Enlarged Stove"><div id=hotspots-container></div></div></div><div id=details-panel class="transition-layout d-flex flex-column gap-3" style=width:0%;opacity:0;max-height:80vh;overflow-y:auto;overflow-x:hidden;padding-right:10px><h5 id=detail-title class="fw-bold m-0 sticky-top bg-white py-2" style=font-family:myjost,sans-serif;z-index:10></h5><div id=detail-images-container class="d-flex flex-column gap-3"></div></div></div></div><style>#paige-site-title,#paige-site-title a,#paige-site-description{display:none!important}#paige-site-header{margin-top:2rem!important}@font-face{font-family:myjost;src:url(/fonts/Jost-Regular.ttf)format('truetype');font-weight:400;font-style:normal}#paige-site-menu a{font-family:myjost,sans-serif!important;color:#008b8b!important;font-weight:500!important;letter-spacing:.05em!important;transition:color .2s ease-in-out,opacity .2s ease-in-out!important}#paige-site-menu a:hover{color:#66cdcd!important}#paige-site-menu a:active{color:#004d4d!important}#paige-site-menu a.active,#paige-site-menu a[aria-current=page]{color:#004d4d!important;font-weight:700!important}.stove-option{cursor:pointer;transition:transform .3s ease,box-shadow .3s ease}.stove-option:hover{transform:translateY(-5px)scale(1.02);box-shadow:0 10px 20px rgba(0,0,0,.2)!important}.transition-layout{transition:width .6s cubic-bezier(.25,.8,.25,1),opacity .4s ease}.hotspot-circle{position:absolute;width:90px;height:90px;background:rgba(255,255,255,.2);border:2px solid #24f1ff;border-radius:50%;transform:translate(-50%,-50%);cursor:pointer;box-shadow:0 0 rgba(36,241,255,.7);animation:pulse 2s infinite;transition:background .3s ease}.hotspot-circle:hover{background:rgba(36,241,255,.8)}@keyframes pulse{0%{box-shadow:0 0 rgba(36,241,255,.7)}70%{box-shadow:0 0 0 15px rgba(36,241,255,0)}100%{box-shadow:0 0 rgba(36,241,255,0)}}@media(prefers-color-scheme:dark){#stage-1 h3,#detail-title{color:#24f1ff!important}#detail-title{background-color:#121212!important}}#details-panel::-webkit-scrollbar{width:6px}#details-panel::-webkit-scrollbar-thumb{background-color:#008b8b;border-radius:10px}.breakout-width{width:90vw!important;max-width:1600px!important;position:relative;left:50%;transform:translateX(-50%)}@media(max-width:768px){.breakout-width{width:95vw!important}}</style><script>const detailData={cat:{title:"灶壁猫",images:["/projects/om-and-xiang/cat1.jpg","/projects/om-and-xiang/cat2.jpg","/projects/om-and-xiang/cat3.jpg","/projects/om-and-xiang/cat4.jpg"]},kirtimukha:{title:"饕餮/塌鼻兽",images:["/projects/om-and-xiang/kirtimukha1.jpg","/projects/om-and-xiang/kirtimukha2.jpg","/projects/om-and-xiang/kirtimukha3.jpg","/projects/om-and-xiang/kirtimukha4.jpg"]},stovegod:{title:"灶神",images:["/projects/om-and-xiang/stovegod1.jpg","/projects/om-and-xiang/stovegod2.jpg","/projects/om-and-xiang/stovegod3.jpg","/projects/om-and-xiang/stovegod4.jpg"]},nehulay:{title:"吐宝鼠",images:["/projects/om-and-xiang/nehulay1.jpg","/projects/om-and-xiang/nehulay2.jpg","/projects/om-and-xiang/nehulay3.jpg","/projects/om-and-xiang/nehulay4.jpg"]},"snow-lion":{title:"雪狮",images:["/projects/om-and-xiang/snow-lion1.jpg","/projects/om-and-xiang/snow-lion2.jpg","/projects/om-and-xiang/snow-lion3.jpg","/projects/om-and-xiang/snow-lion4.jpg"]}},stoveHotspots={"/projects/om-and-xiang/stove1.jpg":[{id:"cat",top:"49%",left:"30%"},{id:"kirtimukha",top:"59%",left:"50.5%"}],"/projects/om-and-xiang/stove2.jpg":[{id:"stovegod",top:"43%",left:"51%"}],"/projects/om-and-xiang/stove3.jpg":[{id:"nehulay",top:"50%",left:"42%"},{id:"snow-lion",top:"60%",left:"63%"}]};function enterStage2(e){document.getElementById("stage-1").classList.add("d-none"),document.getElementById("stage-2").classList.remove("d-none"),document.getElementById("main-enlarged-img").src=e;const t=document.getElementById("hotspots-container");t.innerHTML="";const n=stoveHotspots[e];n&&n.forEach(e=>{t.innerHTML+=`<div class="hotspot-circle" style="top: ${e.top}; left: ${e.left};" onclick="showDetails('${e.id}')"></div>`}),resetLayout()}function goBack(){document.getElementById("stage-2").classList.add("d-none"),document.getElementById("stage-1").classList.remove("d-none")}function showDetails(e){document.getElementById("main-image-wrapper").style.width="65%";const t=document.getElementById("details-panel");t.style.width="35%",t.style.opacity="1";const n=detailData[e];document.getElementById("detail-title").innerText=n.title;const s=document.getElementById("detail-images-container");s.innerHTML="",n.images.forEach(e=>{s.innerHTML+=`<img src="${e}" class="img-fluid rounded-3 shadow-sm">`})}function resetLayout(){document.getElementById("main-image-wrapper").style.width="100%";const e=document.getElementById("details-panel");e.style.width="0%",e.style.opacity="0"}</script>]]></content><id>tag:zhong-yuxi.github.io,0001-01-01:/zh/projects/om-and-xiang/</id><link href="https://zhong-yuxi.github.io/zh/projects/om-and-xiang/" hreflang="zh-cn" rel="alternate" type="text/html"/><link href="https://zhong-yuxi.github.io/projects/om-and-xiang/" hreflang="en-us" rel="canonical" type="text/html"/><published>0001-01-01T00:00:00Z</published><rights type="html">© 2026 Yuxi Zhong</rights><updated>0001-01-01T00:00:00Z</updated></entry></feed>